# ============================================================================
# .sync-env — Config for sync-db.sh
# Copy this to .sync-env and fill in your values
# ============================================================================

# ── Remote server ────────────────────────────────────────────────────────────
REMOTE_HOST="your-ec2-public-ip-or-hostname"
REMOTE_USER="ec2-user"
REMOTE_ENV_PATH="/home/ec2-user/stojan-shop-new/backend/.env"

# SSH key path (Git Bash format: /c/Users/karol/.ssh/stojan-key.pem)
SSH_KEY_PATH="/c/Users/YourUser/.ssh/stojan-key.pem"

# ── AWS (for security group open/close) ──────────────────────────────────────
SG_ID="sg-xxxxxxxxxxxxxxxxx"
AWS_REGION="eu-central-1"
# AWS credentials — either set here or rely on `aws configure`
# AWS_ACCESS_KEY_ID="..."
# AWS_SECRET_ACCESS_KEY="..."

# ── Local PostgreSQL ─────────────────────────────────────────────────────────
LOCAL_DB_NAME="stojan_shop"
LOCAL_DB_HOST="localhost"
LOCAL_DB_PORT="5432"
LOCAL_DB_USER="postgres"
LOCAL_DB_PASSWORD="your-local-pg-password"
