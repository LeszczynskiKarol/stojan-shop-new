---
// frontend/src/components/shop/CategoryCard.astro
interface Props {
  category: any;
}

const { category } = Astro.props;
const image = category.image || null;
const productCount = category._count?.products ?? category.productCount ?? null;

// Strip HTML from description for display
function stripHtml(html: string | null | undefined): string {
  if (!html) return '';
  return html
    .replace(/<[^>]+>/g, '')
    .replace(/&oacute;/g, 'ó').replace(/&ndash;/g, '–').replace(/&amp;/g, '&')
    .replace(/&nbsp;/g, ' ').replace(/&[a-z]+;/gi, '').replace(/&#\d+;/g, '')
    .replace(/\s+/g, ' ').trim();
}

const desc = stripHtml(category.description);
---

<a
  href={`/${category.slug}`}
  class="group block bg-card border border-border rounded-xl overflow-hidden hover:shadow-lg hover:border-primary/30 transition-all duration-200"
>
  <div class="aspect-[16/10] overflow-hidden bg-accent relative">
    {image ? (
      <img
        src={image}
        alt={category.name}
        class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300"
        loading="lazy"
        width="400"
        height="250"
      />
    ) : (
      <div class="w-full h-full flex items-center justify-center bg-gradient-to-br from-primary/10 to-primary/5">
        <svg class="w-12 h-12 text-primary/30" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
          <path d="M13 10V3L4 14h7v7l9-11h-7z"/>
        </svg>
      </div>
    )}
    {productCount !== null && productCount > 0 && (
      <span class="absolute top-3 right-3 bg-primary text-primary-foreground text-xs font-bold px-2.5 py-1 rounded-full shadow-sm">
        {productCount}
      </span>
    )}
  </div>
  <div class="p-4">
    <h3 class="font-semibold text-card-foreground group-hover:text-primary transition-colors text-base">
      {category.name}
    </h3>
    {desc && (
      <p class="text-sm text-muted-foreground mt-1 line-clamp-2">{desc}</p>
    )}
  </div>
</a>