---
// frontend/src/pages/[categorySlug]/index.astro
import BaseLayout from '@/layouts/BaseLayout.astro';
import CategoryProducts from '@/components/shop/CategoryProducts';
import ExpandableDescription from '@/components/shop/ExpandableDescription';
import CityLandingPage from '@/components/shop/CityLandingPage.astro';
import type { CityData } from '@/components/shop/CityLandingPage.astro';
import { getCategory, getProducts, getProductsByPower, getLegalPage } from '@/lib/api';

// === Local landing pages (geo-modyfikowane query z GSC) ===
// Whitelist top miast PL. URL pattern: /silniki-elektryczne-{slug-miasta}.
// UCZCIWE strony — nie udajemy oddziałów, jasno mówią o jednym magazynie w Pigży.
const CITY_DATA: Record<string, CityData> = {
  'warszawa': {
    name: 'Warszawa',
    region: 'mazowieckim',
    distanceKm: 240,
    industryHint:
      'Warszawa to centrum biznesowo-administracyjne — najczęściej zamawia się tu silniki do serwisu klimatyzacji i wentylacji w biurowcach, silniki do bram garażowych oraz motoreduktory do automatyki budynkowej. Dla większych projektów (centra handlowe, magazyny logistyczne) realizujemy dostawy paletowe.',
  },
  'krakow': {
    name: 'Kraków',
    region: 'małopolskim',
    distanceKm: 440,
    industryHint:
      'Małopolska to silna obecność branży automotive i przemysłu okołoenergetycznego. Dla klientów z Krakowa najczęściej wysyłamy motoreduktory do linii produkcyjnych oraz silniki trójfazowe średnich mocy (3–11 kW) do warsztatów obróbczych i mechaniki maszyn.',
  },
  'wroclaw': {
    name: 'Wrocław',
    region: 'dolnośląskim',
    distanceKm: 350,
    industryHint:
      'Wrocław i Dolny Śląsk to ważne centrum motoryzacyjne (m.in. fabryki Toyoty, Volkswagena, Bosch). Często dostarczamy do tego regionu motoreduktory NORD i SEW do automatyki produkcyjnej oraz silniki z hamulcem do wciągarek warsztatowych.',
  },
  'poznan': {
    name: 'Poznań',
    region: 'wielkopolskim',
    distanceKm: 200,
    industryHint:
      'Wielkopolska to przemysł spożywczy (mleczarnie, masarnie, browary) i targowy. Dla klientów z Poznania najczęściej zamawiane są motoreduktory do maszyn gastronomicznych (m.in. maszynki do mięsa typu 32, 42) oraz silniki jednofazowe 230V do drobnej produkcji.',
  },
  'gdansk': {
    name: 'Gdańsk',
    region: 'pomorskim',
    distanceKm: 180,
    industryHint:
      'Trójmiasto to mocna branża morska (stocznie, porty, logistyka kontenerowa) i przemysł rafineryjny. Często dostarczamy tutaj silniki trójfazowe dużych mocy, silniki z wykonaniem Ex (przeciwwybuchowe) oraz motoreduktory ślimakowe do wciągarek portowych i dźwigów.',
  },
  'katowice': {
    name: 'Katowice',
    region: 'śląskim',
    distanceKm: 420,
    industryHint:
      'Śląsk to historyczne centrum górnictwa, hutnictwa i energetyki. Najczęściej trafiają tu silniki trójfazowe wysokich mocy (15–200 kW), silniki w wykonaniu przeciwwybuchowym Ex (kopalnie, zakłady chemiczne) oraz motoreduktory do maszyn hutniczych i kruszarek. Również obsługujemy klientów z <a href="/silniki-elektryczne-bielsko-biala">Bielska-Białej</a> i całej aglomeracji.',
  },
  'lodz': {
    name: 'Łódź',
    region: 'łódzkim',
    distanceKm: 200,
    industryHint:
      'Łódź to centrum logistyczne kraju (skrzyżowanie A1/A2) oraz historyczne zaplecze tekstylne. Najczęściej dostarczamy tu silniki do maszyn pakujących, taśm przenośnikowych w magazynach oraz silniki jednofazowe do drobnej produkcji.',
  },
  'bydgoszcz': {
    name: 'Bydgoszcz',
    region: 'kujawsko-pomorskim',
    distanceKm: 50,
    industryHint:
      'Bydgoszcz to nasz <strong>najbliższy duży rynek</strong> — 50 km od Pigży. Dla klientów z Bydgoszczy realizujemy dostawy w ciągu 1 dnia roboczego, możemy też przywieźć większe zamówienia własnym transportem. Mocna branża to PESA (tabor kolejowy) i przemysł elektromaszynowy.',
  },
  'torun': {
    name: 'Toruń',
    region: 'kujawsko-pomorskim',
    distanceKm: 13,
    industryHint:
      'Toruń to nasze najbliższe sąsiedztwo — <strong>13 km od magazynu w Pigży</strong>. Dla klientów z Torunia chętnie umawiamy się na <strong>odbiór osobisty</strong> (taniej i szybciej niż kurierem) lub realizujemy dostawę tego samego dnia. Mocny przemysł lokalny to chemia (Anwil w okolicy), elektronika (Apator) i produkcja maszynowa.',
  },
  'lublin': {
    name: 'Lublin',
    region: 'lubelskim',
    distanceKm: 410,
    industryHint:
      'Lubelskie to rolnictwo, przemysł spożywczy i logistyka wschodnia. Najczęściej dostarczamy do tego regionu silniki do maszyn rolniczych, motoreduktory do pasz/mieszadeł oraz silniki trójfazowe średnich mocy do warsztatów obróbczych.',
  },
  'bielsko-biala': {
    name: 'Bielsko-Biała',
    region: 'śląskim',
    distanceKm: 470,
    industryHint:
      'Bielsko-Biała to silne centrum motoryzacyjne (Fiat, Magneti Marelli) i automatyki przemysłowej. Często dostarczamy do tego regionu motoreduktory do robotów liniowych i przekładnie do maszyn obróbczych.',
  },
};

const { categorySlug } = Astro.params;

// City dispatch — przed całą resztą routingu
const cityMatch = categorySlug?.match(/^silniki-elektryczne-([a-z][a-z-]*)$/);
const matchedCity = cityMatch && CITY_DATA[cityMatch[1]] ? cityMatch[1] : null;

// Guard: don't handle static file requests
if (categorySlug?.includes('.')) return new Response(null, { status: 404 });

const powerMatch = categorySlug?.match(
  /^silniki-elektryczne-([\d-]+)-kw(?:-([\d]+)-obr)?$/
);

let isPowerPage = false;
let isLegalPage = false;
let legalPage: any = null;
let powerRaw = '';
let rpmStr: string | null = null;
let powerFormatted = '';
let powerProducts: any[] = [];
let category: any = null;
let categoryProducts: any[] = [];

const SITE_URL = 'https://www.silniki-elektryczne.com.pl';

if (powerMatch) {
  isPowerPage = true;

  // SEO: 301 z legacy "0-XX" → kanoniczne "0XX" (sub-1 kW). Oba formaty renderowały
  // identyczną treść z self-canonical — duplikat. Kanonem jest forma zwarta ("009"),
  // bo używa jej DB Category i stopka, a Google już ją indeksuje.
  const legacySub1kW = powerMatch[1].match(/^0-(\d{1,2})$/);
  if (legacySub1kW) {
    const canonicalPowerSlug = '0' + legacySub1kW[1].padEnd(2, '0');
    const rpmPart = powerMatch[2] ? `-${powerMatch[2]}-obr` : '';
    return Astro.redirect(`/silniki-elektryczne-${canonicalPowerSlug}-kw${rpmPart}`, 301);
  }

  powerRaw = powerMatch[1].replace(/-/g, '.');
  // Handle sub-1kW slugs: "037" → "0.37", "075" → "0.75", "009" → "0.09"
  if (/^0\d{2}$/.test(powerRaw)) {
    powerRaw = powerRaw[0] + '.' + powerRaw.slice(1);
  }
  const power = parseFloat(powerRaw);
  rpmStr = powerMatch[2] || null;
  powerFormatted = powerRaw.replace('.', ',');
  if (isNaN(power)) return Astro.rewrite('/404');
  const data = await getProductsByPower(powerRaw, rpmStr || undefined);
  powerProducts = (data?.products || []).filter((p: any) => p.stock > 0);
  // SEO: power-pages bez produktów w magazynie zwracają 404 zamiast pustego 200 (soft 404).
  // Sitemap-power-pages.xml też powinno być filtrowane po stocku — TODO.
  if (powerProducts.length === 0) return Astro.rewrite('/404');
}

// === SEO: paginacja SSR + detekcja filtrów ===
// Filtr — noindex (treść zależna od użytkownika).
// Page (paginacja) — index, self-canonical (każda strona to inny zestaw produktów).
const FILTER_PARAMS = ['q', 'cat', 'mfr', 'cond', 'kw', 'kwmin', 'kwmax', 'rpm', 'rpmr', 'obrmin', 'obrmax', 'pmin', 'pmax', 'sort'];
const urlSearchParams = Astro.url.searchParams;
const hasFilterParams = FILTER_PARAMS.some(param => urlSearchParams.has(param));

const PER_PAGE = 24;
const currentPage = Math.max(1, parseInt(urlSearchParams.get('page') || '1') || 1);
let totalProducts = 0;
let totalPages = 1;

if (!isPowerPage && !matchedCity) {
  // Z filtrami: render full list (client-side filtering, jak dotychczas)
  // Bez filtrów: SSR pagination 24/strona — mniejszy HTML, lepszy LCP, prawdziwa paginacja dla Googlebota
  const useServerPagination = !hasFilterParams;
  const productsQuery = useServerPagination
    ? `category=${categorySlug}&limit=${PER_PAGE}&page=${currentPage}&inStock=true&sort=purchaseCount&order=desc`
    : `category=${categorySlug}&limit=2000`;

  const [cat, productsData] = await Promise.all([
    getCategory(categorySlug!),
    getProducts(productsQuery),
  ]);
  if (!cat) {
    legalPage = await getLegalPage(categorySlug!);
    if (!legalPage) return Astro.rewrite('/404');
    isLegalPage = true;
  } else {
    category = cat;
    categoryProducts = productsData?.products || [];
    totalProducts = productsData?.pagination?.total || categoryProducts.length;
    totalPages = productsData?.pagination?.pages || 1;
    // SEO: out-of-range page → 404 (zapobiega indeksowaniu pustych stron typu ?page=999)
    if (useServerPagination && currentPage > 1 && currentPage > totalPages) {
      return Astro.rewrite('/404');
    }
  }
}

// Strip HTML for meta description
function stripHtml(html: string | null | undefined): string {
  if (!html) return '';
  let text = html.replace(/<[^>]+>/g, '')
    .replace(/&oacute;/g, 'ó').replace(/&ndash;/g, '–').replace(/&mdash;/g, '—')
    .replace(/&amp;/g, '&').replace(/&nbsp;/g, ' ').replace(/&[a-z]+;/gi, '')
    .replace(/&#\d+;/g, '').replace(/\s+/g, ' ').trim();
  if (text.length > 160) text = text.slice(0, 160).replace(/\s+\S*$/, '') + '…';
  return text;
}

// ── Legal page render ──
if (isLegalPage && legalPage) {
  const legalTitle = `${legalPage.title} | Silniki Elektryczne`;
  const legalDescription = stripHtml(legalPage.content).slice(0, 160) || legalPage.title;
  // Early return with legal page layout
}

// Total count: dla power-pages = pobrane produkty; dla kategorii = totalProducts (cała kategoria)
// inStockOnPage = produkty z tej strony (do CollectionPage.numberOfItems jeśli brak total)
const inStockOnPage = isPowerPage
  ? powerProducts.length
  : categoryProducts.filter((p: any) => p.stock > 0).length;
const inStockCount = isPowerPage ? powerProducts.length : (totalProducts || inStockOnPage);

const paginationTitleSuffix = !isPowerPage && currentPage > 1 ? ` — strona ${currentPage}` : '';

// Power-page: liczba sztuk + min cena w title → silnie podnosi CTR w SERP (top page
// /silniki-elektryczne-5-5-kw miał 11 098 imp / CTR 1,3% przy pos 5,9 — bardzo nisko).
let powerTitle = '';
if (isPowerPage) {
  const prices = powerProducts
    .map((p: any) => Number(p.price))
    .filter((n: number) => n > 0 && isFinite(n));
  const minPrice = prices.length > 0 ? Math.min(...prices) : 0;
  const priceStr = minPrice > 0 ? ` od ${minPrice.toLocaleString('pl-PL')} zł` : '';
  const cntStr = powerProducts.length > 0 ? ` — ${powerProducts.length} szt.${priceStr}` : '';
  // Słowo "elektryczne" w obu wariantach — keyword consistency z URL i query w GSC.
  powerTitle = rpmStr
    ? `Silniki elektryczne ${powerFormatted} kW ${rpmStr} obr${cntStr} | Stojan`
    : `Silniki elektryczne ${powerFormatted} kW${cntStr} | Stojan`;
}

const title = isPowerPage
  ? powerTitle
  : `${category?.metadata?.title || `${category?.name} - sklep, hurtownia, oferta, ceny, sprzedaż`}${paginationTitleSuffix}`;

const description = isPowerPage
  ? (rpmStr
    ? `Silniki elektryczne o mocy ${powerFormatted} kW i prędkości ${rpmStr} obr/min. ${powerProducts.length} produktów w magazynie.`
    : `Silniki elektryczne o mocy ${powerFormatted} kW. ${powerProducts.length} napędów różnych producentów w atrakcyjnych cenach.`)
  : (category?.metadata?.description || stripHtml(category?.description) || `${category?.name} - ${inStockCount} produktów dostępnych od ręki w sklepie Stojan.`);

// Canonical: power-pages bez query; kategorie z paginacją → self-canonical na konkretną stronę.
const canonical = isPowerPage
  ? (rpmStr ? `/silniki-elektryczne-${powerMatch![1]}-kw-${rpmStr}-obr` : `/silniki-elektryczne-${powerMatch![1]}-kw`)
  : (currentPage > 1 ? `/${categorySlug}?page=${currentPage}` : `/${categorySlug}`);

const breadcrumbLd = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": isPowerPage
    ? [
        { "@type": "ListItem", "position": 1, "name": "Strona główna", "item": SITE_URL },
        { "@type": "ListItem", "position": 2, "name": `Silniki ${powerFormatted} kW`, "item": `${SITE_URL}/silniki-elektryczne-${powerMatch![1]}-kw` },
        ...(rpmStr ? [{ "@type": "ListItem", "position": 3, "name": `${rpmStr} obr/min`, "item": `${SITE_URL}${canonical}` }] : []),
      ]
    : [
        { "@type": "ListItem", "position": 1, "name": "Strona główna", "item": SITE_URL },
        { "@type": "ListItem", "position": 2, "name": category?.name, "item": `${SITE_URL}/${categorySlug}` },
      ]
};

const inStockItems = isPowerPage ? powerProducts : categoryProducts.filter((p: any) => p.stock > 0);
const collectionLd = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  "name": isPowerPage ? `Silniki elektryczne ${powerFormatted} kW${rpmStr ? ` ${rpmStr} obr/min` : ''}` : category?.name,
  "description": description,
  "url": `${SITE_URL}${canonical}`,
  "numberOfItems": inStockCount,
  "mainEntity": {
    "@type": "ItemList",
    "numberOfItems": inStockCount,
    "itemListElement": inStockItems.slice(0, 30).map((p: any, i: number) => ({
      "@type": "ListItem",
      "position": i + 1,
      "item": {
        "@type": "Product",
        "name": p.name,
        "url": `${SITE_URL}/${p.categories?.[0]?.category?.slug || p.categories?.[0]?.slug || categorySlug}/${p.marketplaces?.ownStore?.slug || ''}`,
        "image": p.mainImage || p.images?.[0],
        "brand": { "@type": "Brand", "name": p.manufacturer },
        "offers": {
          "@type": "Offer",
          "priceCurrency": "PLN",
          "price": Number(p.price),
          "availability": "https://schema.org/InStock",
          "itemCondition": p.condition === 'nowy' ? "https://schema.org/NewCondition" : "https://schema.org/UsedCondition",
        }
      }
    }))
  }
};

// SSR pagination helpers — używane tylko dla kategorii (NIE power-pages) bez filtrów.
const showSsrPagination = !isPowerPage && !hasFilterParams && totalPages > 1;
function pageUrl(p: number): string {
  return p === 1 ? `/${categorySlug}` : `/${categorySlug}?page=${p}`;
}
function paginationRange(current: number, total: number): Array<number | 'ellipsis'> {
  if (total <= 7) return Array.from({ length: total }, (_, i) => i + 1);
  const range: Array<number | 'ellipsis'> = [1];
  if (current - 2 > 2) range.push('ellipsis');
  for (let i = Math.max(2, current - 2); i <= Math.min(total - 1, current + 2); i++) range.push(i);
  if (current + 2 < total - 1) range.push('ellipsis');
  range.push(total);
  return range;
}

// Helper: map product for CategoryProducts component
function mapProductForFilter(p: any) {
  return {
    id: p.id,
    name: p.name,
    manufacturer: p.manufacturer,
    price: Number(p.price),
    power: p.power,
    rpm: p.rpm,
    condition: p.condition,
    stock: p.stock,
    mainImage: p.mainImage,
    images: p.images || [],
    shaftDiameter: Number(p.shaftDiameter || 0),
    mechanicalSize: p.mechanicalSize,
    weight: p.weight ? Number(p.weight) : null,
    marketplaces: p.marketplaces,
    categories: p.categories?.map((pc: any) => ({
      id: pc.category?.id || pc.id,
      name: pc.category?.name || pc.name,
      slug: pc.category?.slug || pc.slug,
    })) || [],
    customParameters: p.customParameters || [],
    technicalDetails: p.technicalDetails || '',
  };
}
---

{/* ── LEGAL PAGE RENDER ── */}
{matchedCity ? (
  (() => {
    const city = CITY_DATA[matchedCity];
    const cityCanonical = `/silniki-elektryczne-${matchedCity}`;
    const cityTitle = `Silniki elektryczne ${city.name} — dostawa z magazynu, skup | Stojan`;
    const cityDesc = `Silniki elektryczne i motoreduktory z dostawą do ${city.name} kurierem (1–2 dni). Skup silników z ${city.region}. Magazyn w Pigży k. Torunia (${city.distanceKm} km). Wysyłka 24 h.`;
    const cityJsonLd = {
      "@context": "https://schema.org",
      "@type": "Service",
      "@id": `${SITE_URL}${cityCanonical}#service`,
      "name": `Sprzedaż i skup silników elektrycznych — ${city.name}`,
      "description": cityDesc,
      "url": `${SITE_URL}${cityCanonical}`,
      "serviceType": "Sprzedaż silników elektrycznych z dostawą i skup",
      "provider": {
        "@type": "Organization",
        "name": "Stojan S.C.",
        "url": SITE_URL,
        "telephone": "+48500385112",
        "email": "stojan@silniki-elektryczne.com.pl",
        "taxID": "PL8790003705",
        "address": {
          "@type": "PostalAddress",
          "streetAddress": "Wojewódzka 2",
          "addressLocality": "Pigża",
          "postalCode": "87-152",
          "addressRegion": "kujawsko-pomorskie",
          "addressCountry": "PL"
        }
      },
      "areaServed": { "@type": "City", "name": city.name },
      "hasOfferCatalog": {
        "@type": "OfferCatalog",
        "name": `Silniki elektryczne dostępne dla ${city.name}`,
        "itemListElement": [
          { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Silniki trójfazowe — dostawa kurierska" } },
          { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Silniki jednofazowe 230V — dostawa kurierska" } },
          { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Motoreduktory — dostawa kurierska / paletowa" } },
          { "@type": "Offer", "itemOffered": { "@type": "Service", "name": `Skup silników elektrycznych — ${city.name} i okolice` } }
        ]
      }
    };
    const cityBreadcrumb = {
      "@context": "https://schema.org",
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Strona główna", "item": SITE_URL },
        { "@type": "ListItem", "position": 2, "name": `Silniki elektryczne ${city.name}`, "item": `${SITE_URL}${cityCanonical}` }
      ]
    };
    return (
      <BaseLayout title={cityTitle} description={cityDesc} canonical={cityCanonical} jsonLd={cityJsonLd}>
        <script type="application/ld+json" set:html={JSON.stringify(cityBreadcrumb)} />
        <CityLandingPage citySlug={matchedCity} city={city} />
      </BaseLayout>
    );
  })()
) : isLegalPage && legalPage ? (
  <BaseLayout
    title={`${legalPage.title} | Silniki Elektryczne`}
    description={legalPage.title}
    canonical={`/${categorySlug}`}
  >
    <div class="container mx-auto px-4 py-12 max-w-4xl">
      <nav class="text-sm text-muted-foreground mb-6" aria-label="Ścieżka nawigacji">
        <a href="/" class="hover:text-primary transition-colors">Strona główna</a>
        <span class="mx-2">›</span>
        <span class="text-foreground">{legalPage.title}</span>
      </nav>
      <h1 class="text-3xl font-bold mb-8 text-foreground">{legalPage.title}</h1>
      <div class="prose dark:prose-invert max-w-none" set:html={legalPage.content} />
    </div>
  </BaseLayout>
) : (
  <BaseLayout title={title} description={description} canonical={canonical} jsonLd={breadcrumbLd} noIndex={hasFilterParams}>
    <script type="application/ld+json" set:html={JSON.stringify(collectionLd)} />

    <div class="container mx-auto px-4 py-8">
      <nav class="text-sm text-muted-foreground mb-6" aria-label="Ścieżka nawigacji">
        <a href="/" class="hover:text-primary transition-colors">Strona główna</a>
        <span class="mx-2">›</span>
        {isPowerPage ? (
          rpmStr ? (
            <>
              <a href={`/silniki-elektryczne-${powerMatch![1]}-kw`} class="hover:text-primary transition-colors">Silniki {powerFormatted} kW</a>
              <span class="mx-2">›</span>
              <span class="text-foreground">{rpmStr} obr/min</span>
            </>
          ) : <span class="text-foreground">Silniki {powerFormatted} kW</span>
        ) : <span class="text-foreground">{category?.name}</span>}
      </nav>

      <h1 class="text-3xl font-bold mb-3 text-foreground">
        {isPowerPage ? `Silniki elektryczne ${powerFormatted} kW${rpmStr ? ` ${rpmStr} obr/min` : ''}` : category?.name}
      </h1>

      {/* Description: expandable for categories, static for power pages */}
      {isPowerPage ? (
        <p class="text-sm text-muted-foreground mb-6 max-w-3xl leading-relaxed">
          {rpmStr
            ? `Silniki elektryczne o mocy ${powerFormatted} kW i prędkości ${rpmStr} obr/min. Wszystkie sprawdzone i gotowe do pracy.`
            : `Silniki elektryczne o mocy ${powerFormatted} kW w ofercie sklepu Stojan.`}
        </p>
      ) : category?.description ? (
        <div class="max-w-3xl mb-4">
          <ExpandableDescription client:load html={category.description} maxHeight={80} />
        </div>
      ) : (
        <p class="text-sm text-muted-foreground mb-6">{category?.name} dostępne w sklepie Stojan. Szeroki wybór w atrakcyjnych cenach.</p>
      )}

      {!isPowerPage ? (
        <>
          <CategoryProducts
            client:load
            products={categoryProducts.map(mapProductForFilter)}
            categoryName={category?.name || ''}
          />

          {showSsrPagination && (
            <nav class="mt-8 flex items-center justify-center gap-1 flex-wrap" aria-label="Paginacja produktów">
              {currentPage > 1 && (
                <a
                  href={pageUrl(currentPage - 1)}
                  class="px-3 py-2 rounded-lg border border-border hover:bg-accent text-sm transition-colors"
                  rel="prev"
                >← Poprzednia</a>
              )}

              {paginationRange(currentPage, totalPages).map((p) =>
                p === 'ellipsis' ? (
                  <span class="px-2 text-muted-foreground">…</span>
                ) : p === currentPage ? (
                  <span class="px-3 py-2 rounded-lg bg-primary text-primary-foreground text-sm font-semibold" aria-current="page">{p}</span>
                ) : (
                  <a
                    href={pageUrl(p)}
                    class="px-3 py-2 rounded-lg border border-border hover:bg-accent text-sm transition-colors"
                  >{p}</a>
                )
              )}

              {currentPage < totalPages && (
                <a
                  href={pageUrl(currentPage + 1)}
                  class="px-3 py-2 rounded-lg border border-border hover:bg-accent text-sm transition-colors"
                  rel="next"
                >Następna →</a>
              )}
            </nav>
          )}

          {!isPowerPage && totalProducts > 0 && (
            <p class="text-center text-xs text-muted-foreground mt-3">
              {hasFilterParams
                ? `Pokazano ${categoryProducts.length} produktów`
                : `Strona ${currentPage} z ${totalPages} — łącznie ${totalProducts} produktów w kategorii`}
            </p>
          )}
        </>
      ) : powerProducts.length > 0 ? (
        <CategoryProducts
          client:load
          showCategoryFilter={true}
          products={powerProducts.map(mapProductForFilter)}
          categoryName={`Silniki ${powerFormatted} kW${rpmStr ? ` ${rpmStr} obr/min` : ''}`}
        />
      ) : (
        <div class="text-center py-12 text-muted-foreground">
          <p class="text-lg mb-2">Brak silników o tych parametrach w magazynie</p>
          <p><a href="/kontakt" class="text-primary hover:underline">Skontaktuj się z nami</a> — pomożemy znaleźć odpowiedni silnik.</p>
        </div>
      )}
    </div>
  </BaseLayout>
)}