---
// frontend/src/pages/blog/[slug].astro
import BaseLayout from '@/layouts/BaseLayout.astro';
import { getBlogPost, getBlogPosts } from '@/lib/api';

const { slug } = Astro.params;
const post = await getBlogPost(slug!);

if (!post) return Astro.redirect('/404');

function stripHtml(html: string | null | undefined): string {
  if (!html) return '';
  return html
    .replace(/<[^>]+>/g, '')
    .replace(/&oacute;/g, 'ó').replace(/&ndash;/g, '–').replace(/&mdash;/g, '—')
    .replace(/&amp;/g, '&').replace(/&nbsp;/g, ' ').replace(/&[a-z]+;/gi, '')
    .replace(/&#\d+;/g, '').replace(/\s+/g, ' ').trim();
}

function formatDate(d: string): string {
  return new Date(d).toLocaleDateString('pl-PL', { year: 'numeric', month: 'long', day: 'numeric' });
}

const metaDesc = post.excerpt
  ? stripHtml(post.excerpt).slice(0, 160)
  : stripHtml(post.content).slice(0, 160) + '…';

const SITE_URL = 'https://www.silniki-elektryczne.com.pl';
const postUrl = `${SITE_URL}/blog/${slug}`;

// Extract first image from content for OG
const ogImageMatch = post.content?.match(/<img[^>]+src=["']([^"']+)["']/);
const ogImage = post.featuredImage || ogImageMatch?.[1] || '/logo_dark.png';

const articleLd = {
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": post.title,
  "description": metaDesc,
  "url": postUrl,
  "datePublished": post.createdAt,
  "dateModified": post.updatedAt,
  "author": {
    "@type": "Organization",
    "name": post.author || "Stojan S.C."
  },
  "publisher": {
    "@type": "Organization",
    "name": "Stojan S.C.",
    "url": SITE_URL,
    "logo": { "@type": "ImageObject", "url": `${SITE_URL}/logo_dark.png` }
  },
  ...(ogImage !== '/logo_dark.png' && { "image": ogImage }),
};

const breadcrumbLd = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Strona główna", "item": SITE_URL },
    { "@type": "ListItem", "position": 2, "name": "Blog", "item": `${SITE_URL}/blog` },
    { "@type": "ListItem", "position": 3, "name": post.title, "item": postUrl },
  ]
};

// Fetch other posts for "more articles" section
const allPosts = await getBlogPosts(1) || [];
const otherPosts = allPosts.filter((p: any) => p.slug !== slug).slice(0, 3);
---

<BaseLayout
  title={`${post.title} | Blog Stojan`}
  description={metaDesc}
  canonical={`/blog/${slug}`}
  ogImage={ogImage}
  ogType="article"
  jsonLd={articleLd}
>
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbLd)} />

  <article class="container mx-auto px-4 py-8 max-w-4xl">
    {/* Breadcrumb */}
    <nav class="text-sm text-muted-foreground mb-6" aria-label="Ścieżka nawigacji">
      <a href="/" class="hover:text-primary transition-colors">Strona główna</a>
      <span class="mx-2">›</span>
      <a href="/blog" class="hover:text-primary transition-colors">Blog</a>
      <span class="mx-2">›</span>
      <span class="text-foreground line-clamp-1">{post.title}</span>
    </nav>

    {/* Header */}
    <header class="mb-8">
      <h1 class="text-3xl md:text-4xl font-bold text-foreground leading-tight mb-4">{post.title}</h1>
      <div class="flex flex-wrap items-center gap-4 text-sm text-muted-foreground">
        <time datetime={post.createdAt}>
          {formatDate(post.createdAt)}
        </time>
        {post.author && post.author !== 'Stojan' && (
          <>
            <span class="w-1 h-1 rounded-full bg-muted-foreground"></span>
            <span>{post.author}</span>
          </>
        )}
      </div>
      {post.tags && post.tags.length > 0 && (
        <div class="flex flex-wrap gap-2 mt-4">
          {post.tags.map((tag: string) => (
            <span class="px-3 py-1 text-xs rounded-full bg-primary/10 text-primary font-medium">
              {tag}
            </span>
          ))}
        </div>
      )}
    </header>

    {/* Featured image */}
    {post.featuredImage && (
      <div class="rounded-xl overflow-hidden mb-8 border border-border">
        <img src={post.featuredImage} alt={post.title} class="w-full object-cover" width="900" height="450" />
      </div>
    )}

    {/* Content */}
    <div class="prose dark:prose-invert max-w-none" set:html={post.content} />

    {/* Back to blog */}
    <div class="mt-12 pt-8 border-t border-border">
      <a href="/blog" class="inline-flex items-center gap-2 text-sm text-primary hover:underline font-medium">
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M19 12H5m7-7l-7 7 7 7"/></svg>
        Wróć do listy artykułów
      </a>
    </div>
  </article>

  {/* Other posts */}
  {otherPosts.length > 0 && (
    <section class="bg-card/50 border-t border-border mt-8">
      <div class="container mx-auto px-4 py-12 max-w-4xl">
        <h2 class="text-xl font-bold text-foreground mb-6">Pozostałe artykuły</h2>
        <div class="grid sm:grid-cols-3 gap-4">
          {otherPosts.map((p: any) => (
            <a href={`/blog/${p.slug}`} class="group bg-card border border-border rounded-xl p-5 hover:border-primary/30 hover:shadow-md transition-all">
              <time class="text-xs text-muted-foreground">{formatDate(p.createdAt)}</time>
              <h3 class="text-sm font-semibold text-foreground group-hover:text-primary transition-colors mt-1 leading-snug line-clamp-3">
                {p.title}
              </h3>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}

</BaseLayout>