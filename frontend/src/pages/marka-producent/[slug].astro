---
// frontend/src/pages/marka-producent/[slug].astro
import BaseLayout from '@/layouts/BaseLayout.astro';
import CategoryProducts from '@/components/shop/CategoryProducts';
import { getManufacturer, getProducts } from '@/lib/api';

const { slug } = Astro.params;
if (!slug) return Astro.rewrite('/404');

// Fetch manufacturer info and their products in parallel
// DB stores full path slugs like "marka-producent/siemens"
const manufacturer = await getManufacturer(slug);
const mfrQuery = manufacturer ? manufacturer.name : slug;
const productsData = await getProducts(`manufacturer=${encodeURIComponent(mfrQuery)}&limit=2000`);
const products = productsData?.products || [];

// If no manufacturer record AND no products → 404 (URL nigdy nie istniał)
if (!manufacturer && products.length === 0) return Astro.rewrite('/404');

const mfrName = manufacturer?.name || products[0]?.manufacturer || slug;
const inStockCount = products.filter((p: any) => p.stock > 0).length;
// Manufacturer w DB bez stocku → 200 INDEX + UX z podobnymi producentami.
// Lepiej niż 404: klient z Google ma szansę dobrać u podobnego producenta.

const SITE_URL = 'https://www.silniki-elektryczne.com.pl';

const title = `${mfrName} - silniki elektryczne | Stojan Shop`;
const description = `Silniki elektryczne ${mfrName}. ${inStockCount} produktów dostępnych w magazynie. Sprawdź ofertę i zamów z dostawą!`;
const canonical = `/marka-producent/${slug}`;

const breadcrumbLd = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Strona główna", "item": SITE_URL },
    { "@type": "ListItem", "position": 2, "name": "Producenci", "item": `${SITE_URL}/marka-producent` },
    { "@type": "ListItem", "position": 3, "name": mfrName, "item": `${SITE_URL}${canonical}` },
  ]
};

const inStockItems = products.filter((p: any) => p.stock > 0);
const collectionLd = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  "name": `Silniki elektryczne ${mfrName}`,
  "description": description,
  "url": `${SITE_URL}${canonical}`,
  "numberOfItems": inStockCount,
  "mainEntity": {
    "@type": "ItemList",
    "numberOfItems": inStockCount,
    "itemListElement": inStockItems.slice(0, 30).map((p: any, i: number) => ({
      "@type": "ListItem",
      "position": i + 1,
      "item": {
        "@type": "Product",
        "name": p.name,
        "url": `${SITE_URL}/${p.categories?.[0]?.category?.slug || p.categories?.[0]?.slug || 'trojfazowe'}/${p.marketplaces?.ownStore?.slug || ''}`,
        "image": p.mainImage || p.images?.[0],
        "brand": { "@type": "Brand", "name": mfrName },
        "offers": {
          "@type": "Offer",
          "priceCurrency": "PLN",
          "price": Number(p.price),
          "availability": "https://schema.org/InStock",
          "itemCondition": p.condition === 'nowy' ? "https://schema.org/NewCondition" : "https://schema.org/UsedCondition",
        }
      }
    }))
  }
};

// Helper: map product for CategoryProducts component
function mapProduct(p: any) {
  return {
    id: p.id,
    name: p.name,
    manufacturer: p.manufacturer,
    price: Number(p.price),
    power: p.power,
    rpm: p.rpm,
    condition: p.condition,
    stock: p.stock,
    mainImage: p.mainImage,
    images: p.images || [],
    shaftDiameter: Number(p.shaftDiameter || 0),
    mechanicalSize: p.mechanicalSize,
    weight: p.weight ? Number(p.weight) : null,
    marketplaces: p.marketplaces,
    categories: p.categories?.map((pc: any) => ({
      id: pc.category?.id || pc.id,
      name: pc.category?.name || pc.name,
      slug: pc.category?.slug || pc.slug,
    })) || [],
  };
}
---

<BaseLayout title={title} description={description} canonical={canonical} jsonLd={breadcrumbLd}>
  <script type="application/ld+json" set:html={JSON.stringify(collectionLd)} />

  <div class="container mx-auto px-4 py-8">
    <nav class="text-sm text-muted-foreground mb-6" aria-label="Ścieżka nawigacji">
      <a href="/" class="hover:text-primary transition-colors">Strona główna</a>
      <span class="mx-2">›</span>
      <a href="/marka-producent" class="hover:text-primary transition-colors">Producenci</a>
      <span class="mx-2">›</span>
      <span class="text-foreground">{mfrName}</span>
    </nav>

    <h1 class="text-3xl font-bold mb-3 text-foreground">Silniki elektryczne {mfrName}</h1>
    <p class="text-sm text-muted-foreground mb-6 max-w-3xl leading-relaxed">
      Silniki elektryczne producenta {mfrName} dostępne w sklepie Stojan. Filtruj według kategorii, mocy, obrotów i ceny.
    </p>

    {inStockCount > 0 ? (
      <CategoryProducts
        client:load
        showCategoryFilter={true}
        products={products.map(mapProduct)}
        categoryName={mfrName}
      />
    ) : (
      <div class="max-w-3xl mx-auto py-8">
        <div class="text-center mb-8">
          <div class="text-5xl mb-4">📦</div>
          <p class="text-xl font-semibold text-foreground mb-2">
            Aktualnie brak silników {mfrName} w magazynie
          </p>
          <p class="text-muted-foreground">
            Producent {mfrName} pojawia się okresowo w naszej ofercie. Możesz wybrać silnik podobnego producenta poniżej lub <a href="tel:+48500385112" class="text-primary hover:underline font-medium">zadzwonić: 500 385 112</a> — być może mamy w drodze.
          </p>
        </div>

        <div class="bg-card border border-border rounded-xl p-6 mb-6">
          <h2 class="text-sm font-semibold text-foreground mb-4 text-center">Sprawdź podobne kategorie silników:</h2>
          <div class="grid grid-cols-2 sm:grid-cols-3 gap-2">
            <a href="/trojfazowe" class="block px-4 py-3 rounded-lg border border-border hover:border-primary hover:bg-accent/30 transition-colors text-center text-sm font-medium text-foreground">Silniki trójfazowe</a>
            <a href="/jednofazowe" class="block px-4 py-3 rounded-lg border border-border hover:border-primary hover:bg-accent/30 transition-colors text-center text-sm font-medium text-foreground">Silniki jednofazowe</a>
            <a href="/z-hamulcem" class="block px-4 py-3 rounded-lg border border-border hover:border-primary hover:bg-accent/30 transition-colors text-center text-sm font-medium text-foreground">Silniki z hamulcem</a>
            <a href="/motoreduktory" class="block px-4 py-3 rounded-lg border border-border hover:border-primary hover:bg-accent/30 transition-colors text-center text-sm font-medium text-foreground">Motoreduktory</a>
            <a href="/marka-producent" class="block px-4 py-3 rounded-lg border border-border hover:border-primary hover:bg-accent/30 transition-colors text-center text-sm font-medium text-foreground">Wszyscy producenci</a>
            <a href="/skup-silnikow" class="block px-4 py-3 rounded-lg border border-border hover:border-primary hover:bg-accent/30 transition-colors text-center text-sm font-medium text-foreground">Skup silników</a>
          </div>
        </div>

        <div class="flex flex-col sm:flex-row gap-3 justify-center">
          <a href="tel:+48500385112" class="inline-flex items-center justify-center px-5 py-2.5 bg-primary text-primary-foreground rounded-lg font-medium hover:opacity-90 transition-opacity">Zadzwoń: 500 385 112</a>
          <a href="/kontakt" class="inline-flex items-center justify-center px-5 py-2.5 border border-border text-foreground rounded-lg font-medium hover:bg-accent transition-colors">Zostaw zapytanie</a>
        </div>
      </div>
    )}
  </div>
</BaseLayout>