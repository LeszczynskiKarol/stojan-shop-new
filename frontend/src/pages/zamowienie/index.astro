---
// frontend/src/pages/zamowienie/index.astro
import BaseLayout from '@/layouts/BaseLayout.astro';
import { CheckoutForm } from '@/components/shop/CheckoutForm';
---

<BaseLayout
  title="Zamówienie | Stojan Shop"
  description="Finalizacja zamówienia w sklepie Stojan"
  canonical="/zamowienie"
>
  <div class="container mx-auto px-4 py-8 max-w-6xl">
    <nav class="text-sm text-muted-foreground mb-6">
      <a href="/" class="hover:text-primary transition-colors">Strona główna</a>
      <span class="mx-2">›</span>
      <span class="text-foreground">Zamówienie</span>
    </nav>

    <h1 class="text-2xl md:text-3xl font-bold mb-8 text-foreground">Finalizacja zamówienia</h1>

    <CheckoutForm client:load />
  </div>
</BaseLayout>