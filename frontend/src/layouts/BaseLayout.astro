  <script is:inline>
    // Theme toggle
    document.getElementById('theme-toggle')?.addEventListener('click', function() {
      var d = document.documentElement.classList.toggle('dark');
      document.documentElement.classList.toggle('light', !d);
      localStorage.setItem('theme', d ? 'dark' : 'light');
    });

    // Mobile menu
    (function() {
      var btn = document.getElementById('mobile-menu-toggle');
      var menu = document.getElementById('mobile-menu');
      var hamburger = document.getElementById('hamburger-icon');
      var closeIcon = document.getElementById('close-icon');
      if (!btn || !menu) return;
      btn.addEventListener('click', function() {
        var isOpen = !menu.classList.contains('hidden');
        menu.classList.toggle('hidden');
        if (hamburger) hamburger.classList.toggle('hidden', !isOpen);
        if (closeIcon) closeIcon.classList.toggle('hidden', isOpen);
        btn.setAttribute('aria-expanded', String(!isOpen));
      });
    })();

    // Show admin link if logged in as admin + sync localStorage flag for GA disable.
    // Strzelamy do admin-verify TYLKO gdy flaga admina już istnieje (ustawia ją
    // admin/login.astro). Anonim nigdy jej nie ma → brak zbędnego 401 na każdym
    // publicznym pageloadzie (czyściej w konsoli, mniej requestów, lepszy Best Practices).
    (function() {
      if (localStorage.getItem('admin_logged_in') !== '1') return;
      var apiUrl = window.__PUBLIC_API_URL || window.__API_URL || '';
      fetch(apiUrl + '/api/admin/auth/verify', { credentials: 'include' })
        .then(function(r) { return r.json(); })
        .then(function(d) {
          if (d.success) {
            try { localStorage.setItem('admin_logged_in', '1'); } catch (e) {}
            var el = document.getElementById('admin-link');
            if (el) el.classList.remove('hidden');
          } else {
            try { localStorage.removeItem('admin_logged_in'); } catch (e) {}
          }
        })
        .catch(function() {});
    })();
  </script>
  
  <script> import { tracker } from '@/lib/tracker'; tracker.init(); </script>
    <CookieConsent client:idle />

