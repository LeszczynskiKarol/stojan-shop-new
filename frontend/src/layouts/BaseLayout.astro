---
// frontend/src/layouts/BaseLayout.astro

import '@/styles/globals.css';
import { GlobalSearch } from '@/components/search/GlobalSearch';
import CartDropdown from '@/components/shop/CartDropdown';
import CookieConsent from '@/components/CookieConsent';
import { getPopularProducts } from '@/lib/api';

// Module-level cache dla footera — popular products są wołane na KAŻDEJ stronie SSR.
// 5-minutowy TTL: dane nie zmieniają się często, a wycina ~30-100ms TTFB per request.
let _footerPopularCache: { t: number; data: any[] | null } = { t: 0, data: null };
const FOOTER_CACHE_TTL_MS = 5 * 60 * 1000;
async function getFooterPopular(): Promise<any[] | null> {
  const now = Date.now();
  if (_footerPopularCache.data && now - _footerPopularCache.t < FOOTER_CACHE_TTL_MS) {
    return _footerPopularCache.data;
  }
  const data = await getPopularProducts(30);
  _footerPopularCache = { t: now, data: data || null };
  return data;
}

interface Props {
  title: string;
  description: string;
  canonical?: string;
  ogImage?: string;
  ogType?: string;
  noIndex?: boolean;
  jsonLd?: object;
  /** LCP image preload (np. główne zdjęcie produktu) — wstrzykuje <link rel=preload as=image>
   *  w <head>, żeby obraz LCP startował od razu zamiast po sparsowaniu <body>. */
  preloadImage?: string;
  preloadImageSrcset?: string;
  preloadImageSizes?: string;
}

const SITE_URL = 'https://www.silniki-elektryczne.com.pl';
const API_URL = import.meta.env.API_URL || 'http://localhost:4000';
const PUBLIC_API_URL = import.meta.env.PUBLIC_API_URL || API_URL;

const {
  title,
  description,
  canonical,
  ogImage = '/logo_dark.png',
  ogType = 'website',
  noIndex = false,
  jsonLd,
  preloadImage,
  preloadImageSrcset,
  preloadImageSizes,
} = Astro.props;

const canonicalUrl = canonical
  ? `${SITE_URL}${canonical}`
  : `${SITE_URL}${Astro.url.pathname}`;

const fullOgImage = ogImage.startsWith('http') ? ogImage : `${SITE_URL}${ogImage}`;

// ── Footer data ──────────────────────────────────────────────
function powerToSlug(p: string): string {
  const num = parseFloat(p.replace(",", "."));
  if (num < 1) return p.replace(",", "").padStart(3, "0");
  return p.replace(",", "-");
}

const rpmColumns = [
  { rpm: "700",  powers: ["0,75","1,1","1,5","2,2","3","4","5,5","7,5"] },
  { rpm: "900",  powers: ["0,75","1,1","1,5","2,2","3","4","5,5","7,5"] },
  { rpm: "1400", powers: ["0,75","1,1","1,5","2,2","3","4","5,5","7,5","11","18,5"] },
  { rpm: "2900", powers: ["0,75","1,1","1,5","2,2","3","4","5,5","7,5","11","18,5"] },
];

const powerLinks = [
  "0,09","0,12","0,18","0,25","0,37","0,55","0,75",
  "1,1","1,5","2,2","3","4","5,5","7,5",
  "11","18,5","22","30","55","75","110","160","200",
];
const powerCols: string[][] = [[],[],[]];
powerLinks.forEach((p, i) => powerCols[i % 3].push(p));

const manufacturers = [
  { name: "OMEC Motors", slug: "omec-motors" },
  { name: "SEW Eurodrive", slug: "sew-eurodrive" },
  { name: "Besel", slug: "besel" },
  { name: "Tamel", slug: "tamel" },
  { name: "Lenze", slug: "lenze" },
  { name: "Nidec", slug: "nidec" },
  { name: "ABB", slug: "abb" },
  { name: "Moll Motor", slug: "moll-motor" },
  { name: "Cantoni Group", slug: "cantoni-group" },
  { name: "Indukta", slug: "indukta" },
  { name: "Siemens", slug: "siemens" },
  { name: "Celma", slug: "celma" },
  { name: "EMIT", slug: "emit" },
  { name: "NORD", slug: "nord" },
  { name: "Bauer Gear Motor", slug: "bauer-gear-motor" },
  { name: "Hoyer", slug: "hoyer" },
];
const mfrCols: typeof manufacturers[] = [[],[]];
manufacturers.forEach((m, i) => mfrCols[i % 2].push(m));

const legalLinks = [
  { label: "Kontakt", href: "/kontakt" },
  { label: "Formy płatności", href: "/formy-platnosci" },
  { label: "Koszty i czas wysyłki", href: "/koszty-i-czas-wysylki" },
  { label: "Odstąpienie od umowy", href: "/odstapienie-od-umowy" },
  { label: "Regulamin sklepu", href: "/regulamin-sklepu" },
  { label: "Warunki zwrotu", href: "/warunki-zwrotu" },
  { label: "Polityka prywatności", href: "/polityka-prywatnosci" },
  { label: "Przetwarzanie danych", href: "/przetwarzanie-danych-osobowych" },
  { label: "Blog", href: "/blog" },
];

const orderLinks = [
  { label: "Formy płatności", href: "/formy-platnosci" },
  { label: "Koszty i czas wysyłki", href: "/koszty-i-czas-wysylki" },
  { label: "Odstąpienie od umowy", href: "/odstapienie-od-umowy" },
];

const payments = [
  { src: "/payments/stripe.png", alt: "Stripe" },
  { src: "/payments/blik.webp", alt: "BLIK" },
  { src: "/payments/przelewy24.png", alt: "Przelewy24" },
  { src: "/payments/visa.png", alt: "Visa" },
  { src: "/payments/mastercard.svg", alt: "Mastercard" },
  { src: "/payments/paypal.webp", alt: "PayPal" },
  { src: "/payments/gpay.png", alt: "Google Pay" },
  { src: "/payments/applepay.png", alt: "Apple Pay" },
  { src: "/payments/dhl.png", alt: "DHL" },
];

const currentYear = new Date().getFullYear();

// ── Polecane silniki (rotational) ─────────────────────────────
// Wybiera 6 losowych produktów z top-30 by purchaseCount. Każdy render = inny zestaw,
// więc internal-link juice rozkłada się równomiernie na popularne produkty zamiast
// koncentrować się na top-8 zawsze tych samych. Cel: zmniejszyć liczbę orphan pages
// z ruchem (audyt: 129 orphans z clicks≥1 lub impr≥5).
let footerPicks: Array<{ name: string; href: string; manufacturer: string | null; power: string | null }> = [];
try {
  const popular = await getFooterPopular();
  if (popular && popular.length > 0) {
    const shuffled = [...popular]
      .filter((p: any) => p.stock > 0 && p.marketplaces?.ownStore?.slug)
      .sort(() => Math.random() - 0.5)
      .slice(0, 6);
    footerPicks = shuffled.map((p: any) => {
      const catSlug = p.categories?.[0]?.category?.slug || p.categories?.[0]?.slug || 'trojfazowe';
      const prodSlug = p.marketplaces.ownStore.slug;
      const rawPower = typeof p.power === 'object' ? p.power?.value : p.power;
      const pwrClean = rawPower ? String(rawPower).replace(/\s*kw\s*/gi, ' ').trim() : null;
      // First-letter uppercase
      const nm = p.name ? p.name.charAt(0).toUpperCase() + p.name.slice(1).toLowerCase() : '';
      return {
        name: nm,
        href: `/${catSlug}/${prodSlug}`,
        manufacturer: p.manufacturer || null,
        power: pwrClean ? `${pwrClean} kW` : null,
      };
    });
  }
} catch {
  // Failsafe — pusty footer-block jeśli API padło
  footerPicks = [];
}
---

<!DOCTYPE html>
<html lang="pl" class="light">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />

  <!-- Preconnect do S3 — wszystkie obrazy (karty kategorii/produktów, w tym LCP)
       lecą z s3.eu-north-1.amazonaws.com. Wczesne nawiązanie połączenia ~320 ms LCP. -->
  <link rel="preconnect" href="https://s3.eu-north-1.amazonaws.com" crossorigin />

  {/* Preload obrazu LCP (gł. zdjęcie produktu) — start pobierania w <head>, nie po <body>. */}
  {preloadImage && (
    <link
      rel="preload"
      as="image"
      href={preloadImage}
      imagesrcset={preloadImageSrcset}
      imagesizes={preloadImageSizes}
      fetchpriority="high"
    />
  )}

  <!-- Inter font: SELF-HOSTED (woff2 wariantowy w /fonts) — @font-face w globals.css.
       Brak round-tripu do fonts.googleapis.com/gstatic.com. Preload latin-ext, bo
       polskie znaki diakrytyczne są na pierwszym widoku każdej strony. -->
  <link
    rel="preload"
    as="font"
    type="font/woff2"
    href="/fonts/inter-latin-ext-wght.woff2"
    crossorigin
  />
  <!-- wyłączenie zbierania danych dla admina w google analytics
       Source of truth: localStorage('admin_logged_in') na domenie sklepu.
       Cookie 'admin_session' jest na api.torweb.pl (cross-domain) i niewidoczne stąd. -->
<script is:inline>
  (function() {
    try {
      if (localStorage.getItem('admin_logged_in') === '1') {
        window['ga-disable-G-VPV7V6L3KW'] = true;
        window['ga-disable-AW-988030143'] = true;
        window.__IS_ADMIN = true;
      }
    } catch (e) {}
  })();
</script>
  
  <!-- ═══ CONSENT MODE V2 + GOOGLE TAGS ═══ -->
  <!-- 1. Consent defaults (MUST be first!) -->
  <script is:inline>
    window.dataLayer = window.dataLayer || [];
    function gtag(){dataLayer.push(arguments);}
    
    // Default: all denied until user consents
    gtag('consent', 'default', {
      'ad_storage': 'denied',
      'ad_user_data': 'denied',
      'ad_personalization': 'denied',
      'analytics_storage': 'denied',
      'functionality_storage': 'granted',
      'security_storage': 'granted',
      'wait_for_update': 500
    });
    
    // Better attribution without cookies
    gtag('set', 'url_passthrough', true);
    gtag('set', 'ads_data_redaction', true);
    
    // If user already consented, apply immediately
    try {
      var cc = document.cookie.match(/(?:^|;\s*)cookie_consent=([^;]*)/);
      if (cc) {
        var s = JSON.parse(decodeURIComponent(cc[1]));
        if (s && s.version === 1) {
          gtag('consent', 'update', {
            'ad_storage': s.marketing ? 'granted' : 'denied',
            'ad_user_data': s.marketing ? 'granted' : 'denied',
            'ad_personalization': s.marketing ? 'granted' : 'denied',
            'analytics_storage': s.analytics ? 'granted' : 'denied'
          });
        }
      }
    } catch(e) {}
  </script>

  <!-- 2. Load gtag.js LAZY (idle/interaction) — gtag.js to 176 KB blocking script.
       Consent defaults już są wyżej, dataLayer kolejkuje config-y do czasu załadowania. -->
  <script is:inline>
    (function() {
      var loaded = false;
      function loadGtag() {
        if (loaded) return;
        loaded = true;
        var s = document.createElement('script');
        s.async = true;
        s.src = 'https://www.googletagmanager.com/gtag/js?id=G-VPV7V6L3KW';
        document.head.appendChild(s);
        function gtag(){dataLayer.push(arguments);}
        gtag('js', new Date());
        gtag('config', 'G-VPV7V6L3KW', { send_page_view: true, cookie_flags: 'SameSite=Lax;Secure' });
        gtag('config', 'AW-988030143', { cookie_flags: 'SameSite=Lax;Secure' });
      }
      // 1) idle callback (max 3s timeout)
      if ('requestIdleCallback' in window) {
        requestIdleCallback(loadGtag, { timeout: 3000 });
      } else {
        setTimeout(loadGtag, 1500);
      }
      // 2) safety net: pierwsza interakcja użytkownika
      ['scroll','mousemove','touchstart','keydown'].forEach(function(ev) {
        window.addEventListener(ev, loadGtag, { once: true, passive: true });
      });
    })();
  </script>
  <!-- ═══ END CONSENT + GOOGLE TAGS ═══ -->

  <!-- SEO -->
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonicalUrl} />
  <link rel="alternate" hreflang="pl-PL" href={canonicalUrl} />
  <link rel="alternate" hreflang="x-default" href={canonicalUrl} />
  <meta name="robots" content={noIndex ? "noindex, follow, max-image-preview:large" : "index, follow, max-image-preview:large, max-snippet:-1"} />

  <!-- Open Graph -->
  <meta property="og:type" content={ogType} />
  <meta property="og:locale" content="pl_PL" />
  <meta property="og:url" content={canonicalUrl} />
  <meta property="og:site_name" content="Silniki Elektryczne, Motoreduktory - sklep, oferta, sprzedaż" />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:image" content={fullOgImage} />
  <meta property="og:image:width" content="1200" />
  <meta property="og:image:height" content="630" />

  <!-- Twitter Card -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={fullOgImage} />

  <!-- Favicons -->
  <link rel="icon" href="/favicon.ico" sizes="any" />
  <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
  <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
  <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
  <link rel="manifest" href="/site.webmanifest" />

  <!-- Google Verification -->
  <meta name="google-site-verification" content="xFcDL4OEm7GF0jFWvzfsXIleZSpbMUW3QTb7-3r89gM" />

  <!-- JSON-LD -->
  {jsonLd && (
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  )}

  <!-- Inject API URL for client-side components -->
  <script is:inline define:vars={{ API_URL, PUBLIC_API_URL }}>
    window.__API_URL = API_URL;
    window.__PUBLIC_API_URL = PUBLIC_API_URL;
  </script>

  <!-- Dark mode - zero FOUC -->
  <script is:inline>
    (function() {
      var s = localStorage.getItem('theme');
      var d = s === 'dark' || (!s && window.matchMedia('(prefers-color-scheme: dark)').matches);
      document.documentElement.classList.toggle('dark', d);
      document.documentElement.classList.toggle('light', !d);
    })();
  </script>

 
</head>

<body class="min-h-screen bg-background text-foreground flex flex-col overflow-x-hidden">
  

  <!-- ============ HEADER ============ -->
  <header class="sticky top-0 z-50 bg-background border-b border-border" style="backdrop-filter:none">

    <div class="container mx-auto px-4 flex items-center gap-4 h-16">
      <!-- Logo -->
      <a href="/" class="flex items-center shrink-0">
        <img src="/logo_dark.png" alt="Silniki elektryczne sklep" class="h-8" width="120" height="32" />
      </a>

      <!-- Desktop Nav -->
      <nav class="hidden lg:flex items-center gap-5 text-sm font-medium shrink-0" aria-label="Menu główne">
        <a href="/trojfazowe" class="text-muted-foreground hover:text-foreground transition-colors">Trójfazowe</a>
        <a href="/jednofazowe" class="text-muted-foreground hover:text-foreground transition-colors">Jednofazowe</a>
        <a href="/z-hamulcem" class="text-muted-foreground hover:text-foreground transition-colors">Z hamulcem</a>
        <a href="/motoreduktory" class="text-muted-foreground hover:text-foreground transition-colors">Motoreduktory</a>
        <a href="/akcesoria" class="text-muted-foreground hover:text-foreground transition-colors">Akcesoria</a>
      </nav>

      <!-- Global Search (desktop) -->
      <div class="hidden md:block flex-1 max-w-sm ml-auto">
        <GlobalSearch client:load variant="header" />
      </div>

      <!-- Action buttons -->
      <div class="flex items-center gap-2 ml-auto md:ml-0 shrink-0">
        <!-- Admin panel link (hidden by default, shown via JS if admin cookie exists) -->
        <a id="admin-link" href="/admin" class="hidden p-2 rounded-lg hover:bg-accent transition-colors text-muted-foreground hover:text-foreground" aria-label="Panel administracyjny" title="Panel admina">
          <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"/></svg>
        </a>

        <!-- Theme toggle -->
        <button id="theme-toggle" class="p-2 rounded-lg hover:bg-accent transition-colors text-muted-foreground hover:text-foreground" aria-label="Przełącz motyw">
          <svg class="w-5 h-5 hidden dark:block" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="5"/><path d="M12 1v2m0 18v2M4.22 4.22l1.42 1.42m12.72 12.72l1.42 1.42M1 12h2m18 0h2M4.22 19.78l1.42-1.42M18.36 5.64l1.42-1.42"/></svg>
          <svg class="w-5 h-5 dark:hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/></svg>
        </button>

        <CartDropdown client:idle />

        <!-- Mobile hamburger -->
        <button id="mobile-menu-toggle" class="lg:hidden p-2 rounded-lg hover:bg-accent transition-colors text-muted-foreground hover:text-foreground" aria-label="Menu" aria-expanded="false">
          <svg id="hamburger-icon" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/></svg>
          <svg id="close-icon" class="w-5 h-5 hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
        </button>
      </div>
    </div>

    <!-- Mobile menu panel -->
    <div id="mobile-menu" class="hidden lg:hidden border-t border-border bg-background">
      <div class="px-4 py-3 border-b border-border md:hidden">
        <GlobalSearch client:visible variant="header" />
      </div>
      <nav class="px-4 py-3 flex flex-col gap-1" aria-label="Menu mobilne">
        <a href="/trojfazowe" class="py-2.5 px-3 rounded-lg text-sm font-medium text-foreground hover:bg-accent transition-colors">Silniki trójfazowe</a>
        <a href="/jednofazowe" class="py-2.5 px-3 rounded-lg text-sm font-medium text-foreground hover:bg-accent transition-colors">Silniki jednofazowe</a>
        <a href="/z-hamulcem" class="py-2.5 px-3 rounded-lg text-sm font-medium text-foreground hover:bg-accent transition-colors">Silniki z hamulcem</a>
        <a href="/motoreduktory" class="py-2.5 px-3 rounded-lg text-sm font-medium text-foreground hover:bg-accent transition-colors">Motoreduktory</a>
        <a href="/dwubiegowe" class="py-2.5 px-3 rounded-lg text-sm font-medium text-foreground hover:bg-accent transition-colors">Silniki dwubiegowe</a>
        <a href="/pompy" class="py-2.5 px-3 rounded-lg text-sm font-medium text-foreground hover:bg-accent transition-colors">Pompy</a>
        <a href="/wentylatory-przemyslowe" class="py-2.5 px-3 rounded-lg text-sm font-medium text-foreground hover:bg-accent transition-colors">Wentylatory</a>
        <a href="/akcesoria" class="py-2.5 px-3 rounded-lg text-sm font-medium text-foreground hover:bg-accent transition-colors">Akcesoria</a>
        <a href="/skup-silnikow" class="py-2.5 px-3 rounded-lg text-sm font-medium text-foreground hover:bg-accent transition-colors">Skup silników</a>
        <div class="border-t border-border my-1"></div>
      </nav>
    </div>
  </header>

  <!-- Main -->
  <main class="flex-1">
    <slot />
  </main>

  <!-- ============ FOOTER ============ -->
  <footer class="bg-background border-t border-border mt-auto">
    <div class="container mx-auto px-4 py-8">

      <!-- SEKCJA 1: Moc + Obroty -->
      <div class="mb-8 pb-8 border-b border-border">
        <h3 class="font-bold mb-4 text-sm text-foreground">Popularne silniki według mocy i obrotów</h3>
        <div class="grid grid-cols-2 md:grid-cols-4 gap-6 text-xs text-muted-foreground">
          {rpmColumns.map(({ rpm, powers }) => (
            <div>
              <h4 class="font-semibold text-foreground mb-2">{rpm} obr/min</h4>
              <div class="space-y-0.5">
                {powers.map((p) => (
                  <a href={`/silniki-elektryczne-${powerToSlug(p)}-kw-${rpm}-obr`} class="block hover:underline hover:text-primary transition-colors">
                    {p} kW {rpm} obr
                  </a>
                ))}
              </div>
            </div>
          ))}
        </div>
      </div>

      <!-- SEKCJA 1b: Motoreduktory (landingi wg marki/typu) — site-wide internal links.
           Synchronizuj z MOTO_LANDINGS w frontend/src/pages/[categorySlug]/index.astro. -->
      <div class="mb-8 pb-8 border-b border-border">
        <h3 class="font-bold mb-4 text-sm text-foreground">Motoreduktory</h3>
        <div class="flex flex-wrap gap-x-4 gap-y-1 text-xs text-muted-foreground">
          <a href="/motoreduktory" class="hover:underline hover:text-primary transition-colors">Wszystkie motoreduktory</a>
          <a href="/motoreduktory-sew" class="hover:underline hover:text-primary transition-colors">Motoreduktory SEW</a>
          <a href="/motoreduktory-nord" class="hover:underline hover:text-primary transition-colors">Motoreduktory NORD</a>
          <a href="/motoreduktory-lenze" class="hover:underline hover:text-primary transition-colors">Motoreduktory Lenze</a>
          <a href="/motoreduktory-walcowe" class="hover:underline hover:text-primary transition-colors">Motoreduktory walcowe</a>
          <a href="/motoreduktory-plaskie" class="hover:underline hover:text-primary transition-colors">Motoreduktory płaskie</a>
          <a href="/motoreduktory-katowe" class="hover:underline hover:text-primary transition-colors">Motoreduktory kątowe</a>
          <a href="/motoreduktory-z-hamulcem" class="hover:underline hover:text-primary transition-colors">Motoreduktory z hamulcem</a>
          <a href="/motoreduktory-wolnoobrotowe" class="hover:underline hover:text-primary transition-colors">Motoreduktory wolnoobrotowe</a>
        </div>
      </div>

      <!-- SEKCJA 2: Grid z kolumnami -->
      <div class="grid grid-cols-12 gap-x-4 gap-y-8">

        <!-- Moce silników -->
        <div class="col-span-12 lg:col-span-3">
          <h3 class="font-bold mb-3 text-sm text-foreground">Moce silników</h3>
          <div class="grid grid-cols-3 gap-2">
            {powerCols.map((col) => (
